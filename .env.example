# NEVER commit the actual ".env" file to version control.

# "production" enables HTTPS enforcement, secure cookies, and disables debug.
# Use "development" only on ur local machine. otherwise u must use production to diable debugger mode
FLASK_ENV=production

# Only relevant when FLASK_ENV=development. Leave unset/0 in production.
FLASK_DEBUG=1

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=Ur_generated_secret_key

# Generate a strong, unique admin password (a password manager works well).
ADMIN_PASSWORD=replace_with_ur_admin_password

# Your live production domain (used for strict CORS).
ALLOWED_ORIGIN=https://www.yourdomain.com

# From your Cloudflare Turnstile dashboard (server-side secret, not the site key).
TURNSTILE_SECRET_KEY=Ur_turnstile_key

# Limit applied to the /book route. Flask-Limiter syntax, e.g.
# "5 per minute", "20 per hour", "3/minute;50/day".
BOOKING_RATE_LIMIT=5 per minute


RATELIMIT_STORAGE_URI=memory://